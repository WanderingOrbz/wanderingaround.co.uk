---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Wandering Around</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      .hero {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
      }

      .hero-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .hero-fallback {
        position: absolute;
        inset: 0;
        background-image: url("/images/backgrounds/index-image.png");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: none;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(rgba(20, 20, 20, 0.55), rgba(20, 20, 20, 0.55));
        pointer-events: none;
      }

      @media (prefers-reduced-motion: reduce) {
        .hero-video {
          display: none;
        }

        .hero-fallback {
          display: block;
        }
      }
    </style>
  </head>

  <body>
    <section class="hero">
      <video
        class="hero-video"
        autoplay
        muted
        loop
        playsinline
        poster="/images/backgrounds/index-image.png"
      >
        <source src="/images/backgrounds/hero-loop.mp4" type="video/mp4" />
      </video>
      <div class="hero-fallback" aria-hidden="true"></div>
    </section>
  </body>
</html>