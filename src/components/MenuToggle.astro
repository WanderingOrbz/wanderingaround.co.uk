---
// A control, not a destination — a future menu overlay will be toggled
// from here, so this is a <button>, not a link. Inert for Version 1.1.
---

<button type="button" class="menu-toggle" aria-label="Menu">
  <span class="menu-toggle__label">Menu</span>
  <svg
    class="menu-toggle__icon"
    width="18"
    height="12"
    viewBox="0 0 18 12"
    fill="none"
    aria-hidden="true"
    focusable="false"
  >
    <line x1="0" y1="1" x2="18" y2="1" stroke="currentColor" />
    <line x1="0" y1="6" x2="18" y2="6" stroke="currentColor" />
    <line x1="0" y1="11" x2="18" y2="11" stroke="currentColor" />
  </svg>
</button>

<style>
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text);
    transition: opacity var(--duration-hover) var(--ease-calm);
  }

  .menu-toggle:hover,
  .menu-toggle:focus-visible {
    opacity: 0.7;
  }

  .menu-toggle__label {
    font-size: 0.7rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
  }
</style>
