---
// Primary vertical navigation. Inert for Version 1.1 — items don't yet
// have real destinations, but stay real, focusable elements so
// keyboard/screen-reader behaviour and visual treatment carry over
// unchanged once routes exist. "Travel" is the one exception: it opens
// the globe overlay (a <button>, since it triggers a dialog rather than
// navigating), not a placeholder link.
const items = [
  { label: 'Travel', openOverlay: 'globe-overlay' },
  { label: 'Photography' },
  { label: 'Projects' },
  { label: 'Journal' },
  { label: 'About' },
];
---

<nav class="site-nav" aria-label="Primary">
  <ul>
    {
      items.map((item) => (
        <li>
          {item.openOverlay ? (
            <button
              type="button"
              data-open-overlay={item.openOverlay}
              aria-haspopup="dialog"
              aria-controls={item.openOverlay}
            >
              {item.label}
            </button>
          ) : (
            <a href="#">{item.label}</a>
          )}
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .site-nav {
    display: flex;
    align-items: center;
    height: 100%;
    padding-inline: clamp(1.5rem, 3vw, 2.75rem);
    background: var(--color-bg);
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vh, 2.25rem);
  }

  a,
  button {
    font-size: 0.7rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-text-muted);
    transition: color var(--duration-hover) var(--ease-calm);
  }

  a:hover,
  a:focus-visible,
  button:hover,
  button:focus-visible {
    color: var(--color-text);
  }

  /*
    Mobile workaround (temporary, see index.astro): below the hero,
    a single vertical list reads as a long, ungrounded stack. Instead
    arrange a 3/2 grid — Photography+About and Travel+Journal paired
    on a row each, Projects on its own row — so it reads as one
    settled block. Desktop/tablet sidebar above is untouched.
  */
  @media (max-width: 720px) {
    .site-nav {
      height: auto;
      justify-content: center;
      padding-block: clamp(2rem, 6vh, 3rem);
    }

    ul {
      display: grid;
      grid-template-columns: max-content max-content;
      justify-content: center;
      column-gap: clamp(2.5rem, 12vw, 4.5rem);
      row-gap: 1.5rem;
    }

    li:nth-child(1) {
      grid-column: 1;
      grid-row: 2;
    } /* Travel */

    li:nth-child(2) {
      grid-column: 1;
      grid-row: 1;
    } /* Photography */

    li:nth-child(3) {
      grid-column: 1;
      grid-row: 3;
    } /* Projects */

    li:nth-child(4) {
      grid-column: 2;
      grid-row: 2;
    } /* Journal */

    li:nth-child(5) {
      grid-column: 2;
      grid-row: 1;
    } /* About */
  }
</style>
